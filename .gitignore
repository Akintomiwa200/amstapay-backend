
## 7. **.gitignore**

```gitignore
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.production
.env.development

# Build outputs
dist/
build/
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-*
.project
.classpath

# Testing
/coverage
.nyc_output

# Production
.env.production

# Docker
docker-compose.override.yml
.docker/

# Database
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp

# Secrets and keys
*.pem
*.key
*.crt
*.p12
.secrets/

# Backup files
*.bak
backups/

# Misc
.cache/
.eslintcache
.prettiercache

# TypeScript
*.tsbuildinfo

# PM2
.pm2/
pm2-*.log

# Redis
dump.rdb

# Uploads
uploads/
public/uploads/

# Certificates
certificates/
*.cert
*.key

# Environment specific
.env.*.local
!.env.example
```
