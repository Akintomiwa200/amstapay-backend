# Node Environment
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/amstapay
MONGODB_TEST_URI=mongodb://localhost:27017/amstapay_test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:8080
CORS_CREDENTIALS=true

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@amstapay.com

# SMS Configuration (Vonage)
VONAGE_API_KEY=your_api_key
VONAGE_API_SECRET=your_api_secret
VONAGE_VIRTUAL_NUMBER=+1234567890

# WhatsApp Configuration (Vonage Messages API)
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY=

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx

# Web3 Configuration
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your-project-id
WEB3_PRIVATE_KEY=your-private-key-for-transactions

# Redis Configuration (for caching, sessions, and Socket.IO)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Socket.IO Configuration
SOCKET_IO_CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
LOG_DIRECTORY=logs

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Two-Factor Authentication
TWO_FACTOR_APP_NAME=Amstapay
TWO_FACTOR_ISSUER=Amstapay

# API Versioning
API_VERSION=v1
API_PREFIX=/api

# Pagination
DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=100

# Queue Configuration
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_PATH=./backups

# Frontend URL
CLIENT_URL=http://localhost:3001